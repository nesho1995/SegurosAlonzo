@model ReclamosWhatsApp.Models.CorreoExtractorConfig

@{
    ViewData["Title"] = "Extractor de correo";
}

<div class="container-fluid mt-4 px-3 px-md-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
        <div>
            <h2>Extractor de correo</h2>
            <p class="text-muted">Configura cómo el sistema identifica reclamos y lee campos del correo.</p>
        </div>
        <a href="/Reclamos" class="btn btn-secondary">Volver</a>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    <form method="post" class="card shadow-sm border-0 p-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="SubjectPattern" class="form-label">Patrón del asunto</label>
            <textarea asp-for="SubjectPattern" class="form-control font-monospace" rows="2"></textarea>
            <span asp-validation-for="SubjectPattern" class="text-danger"></span>
            <small class="text-muted">Debe capturar grupos nombrados: placa y reclamo.</small>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="AseguradoPattern" class="form-label">Asegurado</label>
                <input asp-for="AseguradoPattern" class="form-control font-monospace" />
                <span asp-validation-for="AseguradoPattern" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="PolizaPattern" class="form-label">Póliza</label>
                <input asp-for="PolizaPattern" class="form-control font-monospace" />
                <span asp-validation-for="PolizaPattern" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="CaracteristicasPattern" class="form-label">Características</label>
                <input asp-for="CaracteristicasPattern" class="form-control font-monospace" />
                <span asp-validation-for="CaracteristicasPattern" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="ConductorPattern" class="form-label">Conductor</label>
                <input asp-for="ConductorPattern" class="form-control font-monospace" />
                <span asp-validation-for="ConductorPattern" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="CelularPattern" class="form-label">Celular</label>
                <input asp-for="CelularPattern" class="form-control font-monospace" />
                <span asp-validation-for="CelularPattern" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="FechaPattern" class="form-label">Fecha de notificación</label>
                <input asp-for="FechaPattern" class="form-control font-monospace" />
                <span asp-validation-for="FechaPattern" class="text-danger"></span>
            </div>
            <div class="col-md-12 mb-3">
                <label asp-for="LugarPattern" class="form-label">Lugar del accidente</label>
                <input asp-for="LugarPattern" class="form-control font-monospace" />
                <span asp-validation-for="LugarPattern" class="text-danger"></span>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Guardar configuración</button>
            <a href="/Reclamos/ProbarExtractor" class="btn btn-outline-primary">Probar extractor</a>
        </div>
    </form>
</div>
