<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Seguros CRM")</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <a class="brand" href="@Url.Action("Index", "Home")">
                <span class="brand-mark">S</span>
                <span>
                    <strong>Seguros CRM</strong>
                    <small>Correduría</small>
                </span>
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <nav class="sidebar-nav">
                    <a href="@Url.Action("Index", "Home")">Dashboard</a>
                    <a href="@Url.Action("Index", "Recordatorios")">Recordatorios</a>
                    <a href="@Url.Action("Index", "Pagos")">Pagos</a>
                    <a href="@Url.Action("Index", "Reclamos")">Reclamos</a>
                    <a href="@Url.Action("Index", "Cartera")">Clientes</a>
                    <a href="@Url.Action("Importar", "Cartera")">Importar cartera</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <span class="nav-section">Administración</span>
                        <a href="@Url.Action("ExtractorCorreo", "Configuracion")">Extractor de correo</a>
                        <a href="@Url.Action("Index", "Usuarios")">Usuarios y roles</a>
                    }
                </nav>
            }
        </aside>

        <div class="app-main">
            <header class="topbar">
                <div>
                    <p class="eyebrow">Panel operativo</p>
                    <h1>@(ViewData["Title"] ?? "Seguros CRM")</h1>
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="topbar-actions">
                        <span class="user-pill">@User.Identity.Name</span>
                        <form asp-controller="Auth" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-danger">Cerrar sesión</button>
                        </form>
                    </div>
                }
            </header>

            <main class="content">
                @RenderBody()
            </main>
        </div>
    </div>
</body>
</html>
