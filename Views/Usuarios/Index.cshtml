@model IEnumerable<ReclamosWhatsApp.Models.UserAdminViewModel>
@using ReclamosWhatsApp.Models

@{
    ViewData["Title"] = "Usuarios";
    var roles = (IEnumerable<Role>)ViewBag.Roles;
}

<div class="container-fluid mt-4 px-3 px-md-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
        <div>
            <h2>Usuarios y roles</h2>
            <p class="text-muted">Control de acceso para administradores y usuarios operativos.</p>
        </div>
        <a href="/Reclamos" class="btn btn-secondary">Volver</a>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row g-3">
        <div class="col-lg-4">
            <form method="post" asp-action="Crear" class="card shadow-sm border-0 p-4">
                @Html.AntiForgeryToken()
                <h5>Nuevo usuario</h5>
                <div class="mb-3">
                    <label class="form-label">Usuario</label>
                    <input name="Username" class="form-control" required maxlength="50" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input name="Password" type="password" class="form-control" required minlength="8" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Rol</label>
                    <select name="RoleId" class="form-select">
                        @foreach (var role in roles)
                        {
                            <option value="@role.Id">@role.Name</option>
                        }
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Crear usuario</button>
            </form>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Usuario</th>
                                <th>Rol</th>
                                <th>Estado</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <form method="post" asp-action="Actualizar">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <td><strong>@user.Username</strong></td>
                                    <td>
                                        <select name="roleId" class="form-select form-select-sm">
                                            @foreach (var role in roles)
                                            {
                                                if (role.Id == user.RoleId)
                                                {
                                                    <option value="@role.Id" selected>@role.Name</option>
                                                }
                                                else
                                                {
                                                    <option value="@role.Id">@role.Name</option>
                                                }
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <select name="isActive" class="form-select form-select-sm">
                                            @if (user.IsActive)
                                            {
                                                <option value="true" selected>Activo</option>
                                                <option value="false">Inactivo</option>
                                            }
                                            else
                                            {
                                                <option value="true">Activo</option>
                                                <option value="false" selected>Inactivo</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Guardar</button>
                                    </td>
                                </form>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
