@model ReclamosWhatsApp.Models.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="card" style="max-width: 400px; margin: 40px auto; text-align: center;">
    <h2 style="margin-bottom: 20px;">Iniciar Sesión</h2>
    
    <form asp-action="Login" method="post" style="display: flex; flex-direction: column; gap: 15px;">
        <div asp-validation-summary="ModelOnly" style="color: red;"></div>
        
        <div style="text-align: left;">
            <label asp-for="Username" style="display: block; margin-bottom: 5px; font-weight: 600;">Usuario</label>
            <input asp-for="Username" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;" placeholder="admin" />
            <span asp-validation-for="Username" style="color: red; font-size: 0.9rem;"></span>
        </div>
        
        <div style="text-align: left;">
            <label asp-for="Password" style="display: block; margin-bottom: 5px; font-weight: 600;">Contraseña</label>
            <input asp-for="Password" type="password" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;" placeholder="admin123" />
            <span asp-validation-for="Password" style="color: red; font-size: 0.9rem;"></span>
        </div>
        
        <button type="submit" class="btn btn-primary" style="padding: 12px; font-size: 1rem;">Ingresar</button>
    </form>
</div>
