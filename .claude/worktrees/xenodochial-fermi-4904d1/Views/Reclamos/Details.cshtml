@model ReclamosWhatsApp.Models.ReclamoWhatsApp

@{
    ViewData["Title"] = "Seguimiento del Reclamo";

    var documentos = (IEnumerable<ReclamosWhatsApp.Models.ReclamoDocumento>)ViewBag.Documentos;
    var totalDocs = documentos.Count();
    var docsRecibidos = documentos.Count(x => x.Recibido);
    var porcentaje = totalDocs == 0 ? 0 : (docsRecibidos * 100) / totalDocs;

    var badge = "secondary";

    if (Model.Estado == "COMPLETO") badge = "success";
    else if (Model.Estado == "ENVIADO") badge = "primary";
    else if (Model.Estado == "EN_SEGUIMIENTO") badge = "warning";
    else if (Model.Estado == "ERROR" || Model.Estado == "COMPLETO_ERROR_NOTIFICACION") badge = "danger";
}

<div class="container mt-4">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="fw-bold">Seguimiento del Reclamo</h2>
            <p class="text-muted">Control de documentación, estado y comunicación con el cliente.</p>
        </div>

        <a href="/Reclamos" class="btn btn-secondary">
            Volver al dashboard
        </a>
    </div>

    <div class="row mb-4">

        <div class="col-md-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Datos del reclamo</h5>
                </div>

                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <strong>Conductor / Cliente:</strong><br />
                            @Model.Conductor
                        </div>

                        <div class="col-md-6 mb-2">
                            <strong>Celular:</strong><br />
                            @Model.Celular
                        </div>

                        <div class="col-md-6 mb-2">
                            <strong>Asegurado:</strong><br />
                            @Model.Asegurado
                        </div>

                        <div class="col-md-6 mb-2">
                            <strong>Póliza:</strong><br />
                            @Model.Poliza
                        </div>

                        <div class="col-md-6 mb-2">
                            <strong>Placa:</strong><br />
                            @Model.Placa
                        </div>

                        <div class="col-md-6 mb-2">
                            <strong>Reclamo:</strong><br />
                            @Model.Reclamo
                        </div>

                        <div class="col-md-6 mb-2">
                            <strong>Fecha notificación:</strong><br />
                            @Model.FechaNotificacion?.ToString("dd/MM/yyyy")
                        </div>

                        <div class="col-md-6 mb-2">
                            <strong>Estado:</strong><br />
                            <span class="badge bg-@badge">@Model.Estado</span>
                        </div>

                        <div class="col-md-12 mt-2">
                            <strong>Lugar del accidente:</strong><br />
                            @Model.LugarAccidente
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Progreso</h5>
                </div>

                <div class="card-body">
                    <h2 class="fw-bold">@docsRecibidos / @totalDocs</h2>
                    <p class="text-muted">documentos recibidos</p>

                    <div class="progress mb-3" style="height: 25px;">
                        <div class="progress-bar" role="progressbar" style="width: @porcentaje%;">
                            @porcentaje%
                        </div>
                    </div>

                    @if (Model.Estado == "COMPLETO")
                    {
                        <div class="alert alert-success">
                            Reclamo completo. Todos los documentos fueron recibidos.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            Aún faltan documentos por recibir.
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Checklist de documentos</h5>
        </div>

        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Documento</th>
                        <th>Estado</th>
                        <th>Fecha recibido</th>
                        <th>Acción</th>
                    </tr>
                </thead>

                <tbody>
                @foreach (var doc in documentos)
                {
                    <tr>
                        <td>
                            <strong>@doc.Documento</strong>
                        </td>

                        <td>
                            @if (doc.Recibido)
                            {
                                <span class="badge bg-success">Recibido</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Pendiente</span>
                            }
                        </td>

                        <td>
                            @(doc.FechaRecibido?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                        </td>

                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <form method="post" asp-action="ActualizarDocumento" class="d-inline mb-0">
                                    <input type="hidden" name="documentoId" value="@doc.Id" />
                                    <input type="hidden" name="reclamoId" value="@Model.Id" />
                                    <input type="hidden" name="recibido" value="@(doc.Recibido ? "false" : "true")" />

                                    <button type="submit" class="btn btn-sm @(doc.Recibido ? "btn-outline-danger" : "btn-outline-success")">
                                        @(doc.Recibido ? "Marcar pendiente" : "Marcar recibido")
                                    </button>
                                </form>
                                
                                @if (!doc.Recibido)
                                {
                                    <form method="post" asp-action="SubirDocumento" enctype="multipart/form-data" class="d-inline d-flex gap-2 mb-0">
                                        <input type="hidden" name="documentoId" value="@doc.Id" />
                                        <input type="hidden" name="reclamoId" value="@Model.Id" />
                                        <input type="file" name="archivo" class="form-control form-control-sm" required style="max-width: 200px;" />
                                        <button type="submit" class="btn btn-sm btn-primary">Subir</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row mb-4">

        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Acciones</h5>
                </div>

                <div class="card-body">
                    <form method="post" asp-action="EnviarWhatsApp" class="mb-2">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button class="btn btn-success w-100">
                            Enviar WhatsApp inicial
                        </button>
                    </form>

                    <form method="post" asp-action="EnviarRecordatorioManual" class="mb-2">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button class="btn btn-warning w-100">
                            Enviar recordatorio manual
                        </button>
                    </form>

                    <a href="/Reclamos" class="btn btn-secondary w-100">
                        Volver
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Mensaje WhatsApp generado</h5>
                </div>

                <div class="card-body">
                    <pre style="white-space: pre-wrap; font-family: Arial; font-size: 14px;">@Model.MensajeWhatsApp</pre>
                </div>
            </div>
        </div>

    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-danger text-white">
                Error registrado
            </div>
            <div class="card-body">
                <pre style="white-space: pre-wrap;">@Model.Error</pre>
            </div>
        </div>
    }

</div>
