@model IEnumerable<ReclamosWhatsApp.Models.ReclamoWhatsApp>

@{
    ViewData["Title"] = "Reclamos";
    dynamic stats = ViewBag.Stats;
}

<section class="page-header">
    <div>
        <h2>Seguimiento de reclamos</h2>
        <p class="text-muted">Control de expedientes, documentación y comunicación con clientes.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Reclamos/ProbarExtractor" class="btn btn-warning">Probar extractor</a>
        <a href="/Reclamos/Create" class="btn btn-primary">Nuevo reclamo</a>
    </div>
</section>

<section class="grid kpi-grid mb-4">
    <article class="card metric-card accent-slate">
        <span class="label">Total</span>
        <p class="value">@(stats?.Total ?? 0)</p>
        <p class="hint">Reclamos registrados</p>
    </article>
    <article class="card metric-card accent-blue">
        <span class="label">Pendientes</span>
        <p class="value">@(stats?.Pendientes ?? 0)</p>
        <p class="hint">Enviados o en seguimiento</p>
    </article>
    <article class="card metric-card accent-green">
        <span class="label">Completos</span>
        <p class="value">@(stats?.Completos ?? 0)</p>
        <p class="hint">Con documentación completa</p>
    </article>
    <article class="card metric-card accent-red">
        <span class="label">Errores</span>
        <p class="value">@(stats?.Errores ?? 0)</p>
        <p class="hint">Requieren revisión</p>
    </article>
</section>

<section class="card">
    <div class="card-header section-header">
        <div>
            <h3>Reclamos registrados</h3>
            <p class="text-muted mb-0">Filtra por estado para revisar la bandeja operativa.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Reclamos" class="btn btn-sm btn-outline-dark">Todos</a>
            <a href="/Reclamos?estado=EN_SEGUIMIENTO" class="btn btn-sm btn-outline-warning">Pendientes</a>
            <a href="/Reclamos?estado=COMPLETO" class="btn btn-sm btn-outline-success">Completos</a>
            <a href="/Reclamos?estado=ERROR" class="btn btn-sm btn-outline-danger">Errores</a>
        </div>
    </div>
    <div class="card-body table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Cliente / Conductor</th>
                    <th>Celular</th>
                    <th>Placa</th>
                    <th>Reclamo</th>
                    <th>Estado</th>
                    <th>Fecha</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    var badge = "secondary";

                    if (item.Estado == "COMPLETO") badge = "success";
                    else if (item.Estado == "ENVIADO") badge = "primary";
                    else if (item.Estado == "EN_SEGUIMIENTO") badge = "warning";
                    else if (item.Estado == "ERROR" || item.Estado == "COMPLETO_ERROR_NOTIFICACION") badge = "danger";

                    <tr>
                        <td>
                            <strong>@item.Conductor</strong><br />
                            <small class="text-muted">@item.Asegurado</small>
                        </td>
                        <td>@item.Celular</td>
                        <td>@item.Placa</td>
                        <td>@item.Reclamo</td>
                        <td><span class="badge bg-@badge">@item.Estado</span></td>
                        <td>@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <a href="/Reclamos/Details/@item.Id" class="btn btn-sm btn-outline-primary">Ver seguimiento</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">No hay reclamos registrados todavía.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
