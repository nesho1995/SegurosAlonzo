@model ReclamosWhatsApp.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<section class="page-header">
    <div>
        <h2>Resumen de la correduría</h2>
        <p class="text-muted">Vista rápida de cartera, reclamos, pagos y renovaciones próximas.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Cartera/Importar" class="btn btn-primary">Importar cartera</a>
        <a href="/Reclamos/Create" class="btn btn-outline-primary">Nuevo reclamo</a>
    </div>
</section>

<section class="grid kpi-grid mb-4">
    <article class="card metric-card accent-blue">
        <span class="label">Clientes activos</span>
        <p class="value">@Model.ClientesActivos</p>
        <p class="hint">@Model.TotalClientes clientes registrados</p>
    </article>

    <article class="card metric-card accent-green">
        <span class="label">Pólizas activas</span>
        <p class="value">@Model.PolizasActivas</p>
        <p class="hint">@Model.TotalPolizas pólizas en cartera</p>
    </article>

    <article class="card metric-card accent-amber">
        <span class="label">Renovar pronto</span>
        <p class="value">@Model.PolizasPorVencer30</p>
        <p class="hint">Vencen en los próximos 30 días</p>
    </article>

    <article class="card metric-card accent-red">
        <span class="label">Pagos por revisar</span>
        <p class="value">@Model.PagosPendientes</p>
        <p class="hint">Sin validar, pendientes o en mora</p>
    </article>
</section>

<section class="grid kpi-grid mb-4">
    <article class="card metric-card accent-slate">
        <span class="label">Prima activa</span>
        <p class="value">L @Model.PrimaTotalActiva.ToString("N2")</p>
        <p class="hint">Suma total de pólizas activas</p>
    </article>

    <article class="card metric-card accent-primary">
        <span class="label">Reclamos pendientes</span>
        <p class="value">@Model.ReclamosPendientes</p>
        <p class="hint">@Model.ReclamosTotal reclamos totales</p>
    </article>

    <article class="card metric-card accent-green">
        <span class="label">Reclamos completos</span>
        <p class="value">@Model.ReclamosCompletos</p>
        <p class="hint">Expedientes cerrados</p>
    </article>

    <article class="card metric-card accent-red">
        <span class="label">Alertas críticas</span>
        <p class="value">@(Model.PolizasVencidas + Model.ReclamosErrores + Model.RecordatoriosErrores)</p>
        <p class="hint">@Model.PolizasVencidas vencidas, @Model.ReclamosErrores reclamos, @Model.RecordatoriosErrores recordatorios</p>
    </article>
</section>

<section class="grid two-col">
    <article class="card">
        <div class="card-header section-header">
            <div>
                <h3>Renovaciones próximas</h3>
                <p class="text-muted mb-0">Pólizas activas que vencen pronto.</p>
            </div>
            <a href="/Cartera" class="btn btn-sm btn-outline-primary">Ver cartera</a>
        </div>
        <div class="card-body table-responsive">
            @if (Model.ProximasRenovaciones.Any())
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Cliente</th>
                            <th>Póliza</th>
                            <th>Ramo</th>
                            <th>Vence</th>
                            <th>Prima</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var poliza in Model.ProximasRenovaciones)
                    {
                        var badge = poliza.DiasRestantes <= 7 ? "bg-danger" : poliza.DiasRestantes <= 15 ? "bg-warning" : "bg-primary";
                        <tr>
                            <td>
                                <strong>@poliza.Cliente</strong><br />
                                <small class="text-muted">@poliza.Aseguradora</small>
                            </td>
                            <td>@poliza.NumeroPoliza</td>
                            <td>@poliza.Ramo</td>
                            <td>
                                <span class="badge @badge">@poliza.DiasRestantes días</span><br />
                                <small class="text-muted">@poliza.Hasta?.ToString("dd/MM/yyyy")</small>
                            </td>
                            <td>L @((poliza.PrimaTotal ?? 0).ToString("N2"))</td>
                            <td>
                                <a href="/Cartera/EditarPoliza/@poliza.Id" class="btn btn-sm btn-outline-primary">Revisar</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">No hay renovaciones en los próximos 45 días.</div>
            }
        </div>
    </article>

    <aside class="grid">
        <article class="card">
            <div class="card-header">
                <h3 class="mb-0">Flujo de recordatorios</h3>
            </div>
            <div class="card-body">
                <p class="text-muted">
                    Hay @Model.RecordatoriosPendientes recordatorios pendientes en bandeja para pagos, vencimientos y renovaciones.
                </p>
        <div class="quick-actions">
            <span class="badge bg-warning">Pago pendiente</span>
            <span class="badge bg-primary">Renovación próxima</span>
            <span class="badge bg-danger">Póliza vencida</span>
            <span class="badge bg-success">Enviado correctamente</span>
        </div>
        <div class="mt-2">
            <a href="/Recordatorios" class="btn btn-primary w-100">Abrir bandeja</a>
        </div>
    </div>
</article>

        <article class="card">
            <div class="card-header">
                <h3 class="mb-0">Acciones rápidas</h3>
            </div>
            <div class="card-body quick-actions">
                <a href="/Cartera/Crear" class="btn btn-primary w-100">Nuevo cliente</a>
                <a href="/Cartera/Importar" class="btn btn-outline-primary w-100">Importar Excel</a>
                <a href="/Recordatorios" class="btn btn-outline-primary w-100">Bandeja de recordatorios</a>
                <a href="/Reclamos" class="btn btn-outline-primary w-100">Seguimiento de reclamos</a>
                <a href="/Configuracion/ExtractorCorreo" class="btn btn-outline-primary w-100">Configurar extractor</a>
            </div>
        </article>
    </aside>
</section>
