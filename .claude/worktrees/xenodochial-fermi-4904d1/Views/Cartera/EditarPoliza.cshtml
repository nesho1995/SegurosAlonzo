@model ReclamosWhatsApp.Models.Poliza

@{
    ViewData["Title"] = "Editar póliza";
    var cliente = ViewBag.Cliente as ReclamosWhatsApp.Models.Cliente;
}

<div class="container-fluid mt-4 px-3 px-md-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
        <div>
            <h2>Editar póliza</h2>
            <p class="text-muted">@cliente?.Nombre</p>
        </div>
        <a href="/Cartera/Detalle/@Model.ClienteId" class="btn btn-secondary">Volver</a>
    </div>

    <form method="post" class="card shadow-sm border-0 p-4">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ClienteId" />

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="Aseguradora" class="form-label">Aseguradora</label>
                <input asp-for="Aseguradora" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Ramo" class="form-label">Ramo</label>
                <input asp-for="Ramo" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="EstadoPago" class="form-label">Estado de pago</label>
                <select asp-for="EstadoPago" class="form-select">
                    <option value="SIN_VALIDAR">Sin validar</option>
                    <option value="AL_DIA">Al día</option>
                    <option value="PENDIENTE">Pendiente</option>
                    <option value="MORA">Mora</option>
                </select>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="NumeroPoliza" class="form-label">Póliza</label>
                <input asp-for="NumeroPoliza" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Certificado" class="form-label">Certificado</label>
                <input asp-for="Certificado" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Endoso" class="form-label">Endoso</label>
                <input asp-for="Endoso" class="form-control" />
            </div>

            <div class="col-md-3 mb-3">
                <label asp-for="Cuotas" class="form-label">Cuotas</label>
                <input asp-for="Cuotas" class="form-control" />
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="FormaPago" class="form-label">Forma de pago</label>
                <input asp-for="FormaPago" class="form-control" />
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="Vigencia" class="form-label">Vigencia</label>
                <input asp-for="Vigencia" type="date" class="form-control" />
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="Hasta" class="form-label">Hasta</label>
                <input asp-for="Hasta" type="date" class="form-control" />
            </div>

            <div class="col-md-3 mb-3">
                <label asp-for="PrimaNeta" class="form-label">Prima neta</label>
                <input asp-for="PrimaNeta" class="form-control" />
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="PrimaComercial" class="form-label">Prima comercial</label>
                <input asp-for="PrimaComercial" class="form-control" />
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="Impuesto" class="form-label">Impuesto</label>
                <input asp-for="Impuesto" class="form-control" />
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="PrimaTotal" class="form-label">Prima total</label>
                <input asp-for="PrimaTotal" class="form-control" />
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Plan" class="form-label">Plan</label>
                <input asp-for="Plan" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="SumaAsegurada" class="form-label">Suma asegurada</label>
                <input asp-for="SumaAsegurada" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Vehiculo" class="form-label">Vehículo</label>
                <input asp-for="Vehiculo" class="form-control" />
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Medio" class="form-label">Medio</label>
                <input asp-for="Medio" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="EmisionRenovacion" class="form-label">Emisión/Renovación</label>
                <input asp-for="EmisionRenovacion" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label d-block">Estado</label>
                <label class="form-check">
                    <input asp-for="Activo" class="form-check-input" />
                    <span class="form-check-label">Póliza activa</span>
                </label>
            </div>

            <div class="col-md-12 mb-3">
                <label asp-for="Observaciones" class="form-label">Observaciones</label>
                <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Guardar póliza</button>
            <a href="/Cartera/Detalle/@Model.ClienteId" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>
