@model ReclamosWhatsApp.Models.Recordatorio

@{
    ViewData["Title"] = "Revisar recordatorio";
}

<section class="page-header">
    <div>
        <h2>Revisar recordatorio</h2>
        <p class="text-muted">Edita el mensaje antes de enviarlo al cliente.</p>
    </div>
    <a href="/Recordatorios" class="btn btn-secondary">Volver</a>
</section>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<section class="grid two-col">
    <form method="post" class="card">
        @Html.AntiForgeryToken()
        <div class="card-header">
            <h3 class="mb-0">Mensaje</h3>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label>Asunto</label>
                <input name="asunto" value="@Model.Asunto" class="form-control" required />
            </div>
            <div class="mb-3">
                <label>Mensaje WhatsApp</label>
                <textarea name="mensaje" class="form-control" rows="13" required>@Model.Mensaje</textarea>
            </div>
            <button type="submit" class="btn btn-primary">Guardar cambios</button>
        </div>
    </form>

    <aside class="card">
        <div class="card-header">
            <h3 class="mb-0">Contexto</h3>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label>Tipo</label>
                <span class="badge bg-primary">@Model.Tipo</span>
                <span class="badge bg-secondary">@Model.Referencia</span>
            </div>
            <div class="mb-3">
                <label>Cliente</label>
                <strong>@Model.Cliente</strong>
            </div>
            <div class="mb-3">
                <label>Teléfono</label>
                <span>@Model.Telefono</span>
            </div>
            <div class="mb-3">
                <label>Póliza</label>
                <span>@Model.NumeroPoliza</span>
            </div>
            <div class="mb-3">
                <label>Aseguradora / Ramo</label>
                <span>@Model.Aseguradora @Model.Ramo</span>
            </div>
            <div class="mb-3">
                <label>Fecha objetivo</label>
                <span>@Model.FechaObjetivo?.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="mb-3">
                <label>Estado</label>
                <span class="badge bg-warning">@Model.Estado</span>
            </div>
        </div>
    </aside>
</section>
