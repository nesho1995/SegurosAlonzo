@model ReclamosWhatsApp.Models.PagoBandejaViewModel

@{
    ViewData["Title"] = "Pagos";
    dynamic stats = Model.Stats!;
    string Query(int pagina) =>
        $"/Pagos?estado={Uri.EscapeDataString(Model.Estado ?? "")}&buscar={Uri.EscapeDataString(Model.Buscar ?? "")}&pagina={pagina}&pageSize={Model.PageSize}";
}

<section class="page-header">
    <div>
        <h2>Pagos y cuotas</h2>
        <p class="text-muted">Control de cuotas por póliza, vencimientos y pagos recibidos.</p>
    </div>
    <form method="post" asp-action="GenerarCuotas">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary">Generar cuotas</button>
    </form>
</section>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

<section class="grid kpi-grid mb-4">
    <article class="card metric-card accent-amber">
        <span class="label">Pendientes</span>
        <p class="value">@(stats?.Pendientes ?? 0)</p>
        <p class="hint">Cuotas por cobrar</p>
    </article>
    <article class="card metric-card accent-red">
        <span class="label">Vencidas</span>
        <p class="value">@(stats?.Vencidas ?? 0)</p>
        <p class="hint">Requieren gestión</p>
    </article>
    <article class="card metric-card accent-green">
        <span class="label">Pagadas</span>
        <p class="value">@(stats?.Pagadas ?? 0)</p>
        <p class="hint">Registradas como recibidas</p>
    </article>
    <article class="card metric-card accent-blue">
        <span class="label">Monto pendiente</span>
        <p class="value">L @((decimal)(stats?.MontoPendiente ?? 0)).ToString("N2")</p>
        <p class="hint">Pendiente o vencido</p>
    </article>
</section>

<section class="card mb-4">
    <div class="card-body">
        <form method="get" class="filter-bar payments-filter">
            <div>
                <label>Estado</label>
                <select name="estado" class="form-select">
                    <option value="">Todos</option>
                    <option value="PENDIENTE" selected="@(Model.Estado == "PENDIENTE")">Pendientes</option>
                    <option value="VENCIDA" selected="@(Model.Estado == "VENCIDA")">Vencidas</option>
                    <option value="PAGADA" selected="@(Model.Estado == "PAGADA")">Pagadas</option>
                </select>
            </div>
            <div>
                <label>Buscar</label>
                <input name="buscar" value="@Model.Buscar" class="form-control" placeholder="Cliente, póliza, teléfono..." />
            </div>
            <div>
                <label>Por página</label>
                <select name="pageSize" class="form-select">
                    <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    <option value="100" selected="@(Model.PageSize == 100)">100</option>
                </select>
            </div>
            <div class="filter-actions">
                <button type="submit" class="btn btn-primary">Aplicar</button>
                <a href="/Pagos" class="btn btn-outline-primary">Limpiar</a>
            </div>
        </form>
    </div>
</section>

<section class="card">
    <div class="card-header section-header">
        <div>
            <h3>Cuotas</h3>
            <p class="text-muted mb-0">@Model.Total resultado(s), página @Model.Pagina de @Model.TotalPaginas.</p>
        </div>
    </div>
    <div class="card-body table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Póliza</th>
                    <th>Cuota</th>
                    <th>Vence</th>
                    <th>Monto</th>
                    <th>Estado</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Cuotas.Any())
            {
                foreach (var item in Model.Cuotas)
                {
                    var badge = item.Estado == "PAGADA" ? "bg-success" : item.Estado == "VENCIDA" ? "bg-danger" : "bg-warning";
                    <tr>
                        <td>
                            <strong>@item.Cliente</strong><br />
                            <small class="text-muted">@item.Telefono</small>
                        </td>
                        <td>
                            @item.NumeroPoliza<br />
                            <small class="text-muted">@item.Aseguradora @item.Ramo</small>
                        </td>
                        <td>@item.NumeroCuota</td>
                        <td>@item.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                        <td>L @item.Monto.ToString("N2")</td>
                        <td><span class="badge @badge">@item.Estado</span></td>
                        <td>
                            @if (item.Estado != "PAGADA")
                            {
                                <form method="post" asp-action="MarcarPagada" class="payment-inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="date" name="fechaPago" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control" />
                                    <input name="observaciones" class="form-control" placeholder="Referencia o nota" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Pagada</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted">@item.FechaPago?.ToString("dd/MM/yyyy")</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">No hay cuotas con estos filtros.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="card-footer pager">
        <a class="btn btn-sm btn-outline-primary @(Model.Pagina <= 1 ? "disabled" : "")" href="@Query(Math.Max(1, Model.Pagina - 1))">Anterior</a>
        <span>Página @Model.Pagina de @Model.TotalPaginas</span>
        <a class="btn btn-sm btn-outline-primary @(Model.Pagina >= Model.TotalPaginas ? "disabled" : "")" href="@Query(Math.Min(Model.TotalPaginas, Model.Pagina + 1))">Siguiente</a>
    </div>
</section>
